generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  onboarding Onboarding?
  business   Business?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("password_reset_tokens")
}

model Onboarding {
  id           String    @id @default(cuid())
  userId       String    @unique @map("user_id")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName  String?   @map("company_name")
  industry     String?
  phoneNumber  String?   @map("phone_number")
  teamSize     String?   @map("team_size")
  primaryGoals String[]  @default([]) @map("primary_goals")
  website      String?
  currentStep  Int       @default(1) @map("current_step")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("onboarding")
}

model Business {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  industry  String?
  phone     String?
  website   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  subscription   Subscription?
  aiEmployees    AiEmployee[]
  calls          Call[]
  appointments   Appointment[]
  revenueRecords RevenueRecord[]

  @@map("businesses")
}

model Subscription {
  id                   String    @id @default(cuid())
  businessId           String    @unique @map("business_id")
  business             Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stripeCustomerId     String    @unique @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  stripePriceId        String?   @map("stripe_price_id")
  plan                 String    @default("starter")
  status               String    @default("trialing")
  trialEndsAt          DateTime? @map("trial_ends_at")
  currentPeriodStart   DateTime? @map("current_period_start")
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@map("subscriptions")
}

model AiEmployee {
  id                 String   @id @default(cuid())
  businessId         String   @map("business_id")
  business           Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name               String
  role               String
  status             String   @default("active")
  callsHandled       Int      @default(0) @map("calls_handled")
  leadsQualified     Int      @default(0) @map("leads_qualified")
  appointmentsBooked Int      @default(0) @map("appointments_booked")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  calls        Call[]
  appointments Appointment[]

  @@index([businessId])
  @@map("ai_employees")
}

model Call {
  id           String      @id @default(cuid())
  businessId   String      @map("business_id")
  business     Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  aiEmployeeId String?     @map("ai_employee_id")
  aiEmployee   AiEmployee? @relation(fields: [aiEmployeeId], references: [id], onDelete: SetNull)
  callerName   String?     @map("caller_name")
  callerPhone  String      @map("caller_phone")
  duration     Int
  status       String
  outcome      String?
  summary      String?
  createdAt    DateTime    @default(now()) @map("created_at")

  @@index([businessId, createdAt])
  @@map("calls")
}

model Appointment {
  id            String      @id @default(cuid())
  businessId    String      @map("business_id")
  business      Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  aiEmployeeId  String?     @map("ai_employee_id")
  aiEmployee    AiEmployee? @relation(fields: [aiEmployeeId], references: [id], onDelete: SetNull)
  customerName  String      @map("customer_name")
  customerPhone String?     @map("customer_phone")
  service       String?
  scheduledAt   DateTime    @map("scheduled_at")
  status        String      @default("scheduled")
  source        String?
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([businessId, scheduledAt])
  @@map("appointments")
}

model RevenueRecord {
  id          String   @id @default(cuid())
  businessId  String   @map("business_id")
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  amount      Decimal  @db.Decimal(10, 2)
  source      String?
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([businessId, date])
  @@map("revenue_records")
}
