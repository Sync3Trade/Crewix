# Database
# Use a hosted PostgreSQL URL in production (Neon, Supabase, Vercel Postgres, etc.)
# For SSL-required providers, include ?sslmode=require in the URL.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vertexwork?schema=public"

# Auth.js (required in production)
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-a-secure-secret-with-openssl-rand-base64-32"

# Optional legacy alias supported by the app:
# NEXTAUTH_SECRET="same-value-as-auth-secret"

# App URL used for email links. On Vercel this can be omitted if VERCEL_URL is set.
AUTH_URL="http://localhost:3000"

# Recommended on Vercel when using custom domains or auth host detection issues
AUTH_TRUST_HOST="true"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="VertexWork <onboarding@vertexwork.com>"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_STARTER_YEARLY=""
STRIPE_PRICE_PROFESSIONAL_MONTHLY=""
STRIPE_PRICE_PROFESSIONAL_YEARLY=""
STRIPE_PRICE_BUSINESS_MONTHLY=""
STRIPE_PRICE_BUSINESS_YEARLY=""
STRIPE_PRICE_ENTERPRISE_MONTHLY=""
STRIPE_PRICE_ENTERPRISE_YEARLY=""
